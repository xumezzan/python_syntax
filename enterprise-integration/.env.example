# Пример переменных окружения. Скопируй в .env и заполни.
# РЕАЛЬНЫЙ .env НЕ КОММИТИТСЯ (см. .gitignore). Здесь только моки — никаких
# настоящих SAP/банковских ключей и адресов.

# Подключение к базе. Для docker-compose — строка к контейнеру postgres (host = db).
DATABASE_URL=postgresql://app:app@db:5432/app

# Секрет подписи JWT. В проде — длинная случайная строка из секрет-хранилища.
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Mock-банк (заглушки, не реальные значения).
BANK_BASE_URL=http://mock-bank.local
BANK_API_KEY=mock-bank-key
# Сколько раз mock-банк «моргнёт» 5xx перед успехом — для демонстрации retry (0 = всегда успех).
BANK_FAIL_TIMES=0

# Создавать таблицы при старте. Для рабочего пути через Alembic поставь false.
AUTO_CREATE_TABLES=true
